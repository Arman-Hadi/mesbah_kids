# Copy to .env and adjust values for your environment.
# Django does not load .env automatically; export these or use your process manager.

# Development: leave POSTGRES_DB unset to use SQLite.
# Production: set all POSTGRES_* variables below.

DEBUG=1

# PostgreSQL
POSTGRES_DB=mesbah
POSTGRES_USER=mesbah
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Static and media files (optional; defaults to project static/ and media/)
# STATIC_ROOT=/var/www/mesbah/static
# MEDIA_ROOT=/var/www/mesbah/media
